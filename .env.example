# Evanesca Environment Variables

# Alchemy API Configuration
ALCHEMY_API_KEY=

# Chain-specific Alchemy URLs (without API key)
ALCHEMY_ETH_URL=https://eth-mainnet.g.alchemy.com/v2/
ALCHEMY_BSC_URL=https://bnb-mainnet.g.alchemy.com/v2/
ALCHEMY_ARB_URL=https://arb-mainnet.g.alchemy.com/v2/
ALCHEMY_OPT_URL=https://opt-mainnet.g.alchemy.com/v2/
ALCHEMY_AVAX_URL=https://avax-mainnet.g.alchemy.com/v2/

# AllThatNode API Configuration
ALLTHATNODE_API_KEY=

# Chain-specific AllThatNode URLs (without API key)
ALLTHATNODE_ETH_URL=https://ethereum-mainnet.l.allthatnode.com/archive/evm/
ALLTHATNODE_BSC_URL=https://bsc-mainnet.l.allthatnode.com/archive/evm/
ALLTHATNODE_OPT_URL=https://optimism-mainnet.l.allthatnode.com/archive/evm/
ALLTHATNODE_AVAX_URL=https://avalanche-c-mainnet.l.allthatnode.com/archive/evm/

# Alternative RPC Providers (optional)
INFURA_PROJECT_ID=your-infura-project-id-here

# BigQuery Configuration (optional)
BIGQUERY_PROJECT_ID=your-bigquery-project-id
BIGQUERY_DATASET_ID=your-bigquery-dataset-id

# Etherscan API Keys (optional)
ETHERSCAN_API_KEY=your-etherscan-api-key
BSCSCAN_API_KEY=your-bscscan-api-key
ARBISCAN_API_KEY=your-arbiscan-api-key